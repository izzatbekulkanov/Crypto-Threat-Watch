# Telegram Bot Token (BotFather'dan olinadi)
BOT_TOKEN=your_telegram_bot_token_here

# TON API Key (tonapi.io dan olinadi)
TON_API_KEY=your_ton_api_key_here

# Etherscan API Key (etherscan.io dan olinadi)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# TronGrid API Key (trongrid.io dan olinadi)
TRONGRID_API_KEY=your_trongrid_api_key_here

# L2 API kalitlari (ixtiyoriy, bepul olinadi)
BSCSCAN_API_KEY=your_bscscan_api_key_here
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
BASESCAN_API_KEY=your_basescan_api_key_here

# GitHub Pages Web App URL (username ni o'zgartiring)
# Masalan: https://username.github.io/Crypto-Threat-Watch/
WEBAPP_URL=https://your-username.github.io/Crypto-Threat-Watch/
